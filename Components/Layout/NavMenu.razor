@using BioTwin_AI.Services
@inject CurrentUserSession Session
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BioTwin_AI</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (Session.IsAuthenticated)
        {
            <div class="nav-item px-3 text-white-50 small">
                Signed in as <strong>@Session.Username</strong>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="chat" Match="NavLinkMatch.All">
                    <span class="bi bi-chat-dots-fill" aria-hidden="true"></span> Chat
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="resume/upload">
                    <span class="bi bi-cloud-upload-fill" aria-hidden="true"></span> Upload Resume
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <button class="btn btn-link nav-link text-start" @onclick="LogoutAsync">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Sign Out
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-person-circle" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        AuthService.Logout();
        await Session.ClearPersistedAsync(JS);
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}

