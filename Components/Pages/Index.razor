@page "/"
@page "/chat"
@using BioTwin_AI.Components
@using BioTwin_AI.Models
@rendermode InteractiveServer

<div class="biotwin-container">
    <div class="sidebar-column">
        <ResumeSidebarComponent OnEntrySelected="HandleEntrySelected" />
    </div>
    
    <div class="chat-column">
        <ChatInterfaceComponent />
    </div>

    @if (selectedEntry != null)
    {
        <div class="detail-modal" @onclick="CloseDetail">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h5>@selectedEntry.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="markdown-content">
                        @((MarkupString)selectedEntry.Content)
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .biotwin-container {
        display: flex;
        height: 100vh;
        background: white;
    }

    .sidebar-column {
        flex: 0 0 320px;
        overflow-y: auto;
    }

    .chat-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .detail-modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.2s;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .modal-content {
        background: white;
        border-radius: 8px;
        width: 80%;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px;
        border-bottom: 1px solid #dee2e6;
        background: #f8f9fa;
    }

    .modal-header h5 {
        margin: 0;
    }

    .modal-body {
        padding: 20px;
    }

    .markdown-content {
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .markdown-content h1,
    .markdown-content h2,
    .markdown-content h3 {
        margin-top: 20px;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .markdown-content p {
        margin-bottom: 12px;
    }

    .markdown-content ul,
    .markdown-content ol {
        margin-bottom: 12px;
        padding-left: 20px;
    }

    .markdown-content li {
        margin-bottom: 6px;
    }

    .markdown-content code {
        background: #f0f0f0;
        padding: 2px 6px;
        border-radius: 3px;
        font-family: monospace;
    }

    .markdown-content pre {
        background: #f0f0f0;
        padding: 12px;
        border-radius: 4px;
        overflow-x: auto;
    }
</style>

@code {
    private ResumeEntry? selectedEntry;

    private void HandleEntrySelected(ResumeEntry entry)
    {
        selectedEntry = entry;
    }

    private void CloseDetail()
    {
        selectedEntry = null;
    }
}
