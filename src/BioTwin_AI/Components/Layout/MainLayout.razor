@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="bg-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>
    <div class="orb orb-5"></div>
</div>

<div class="page @( _navCollapsed ? "nav-collapsed" : "" )">
    <div class="sidebar">
        <NavMenu Collapsed="@_navCollapsed" CollapsedChanged="SetNavCollapsed" />
    </div>

    <main>
        @if (!Navigation.Uri.Contains("/login"))
        {
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        }

        <article class="content @(Navigation.Uri.Contains("/login") ? "content-login" : "") px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _navCollapsed;

    private Task SetNavCollapsed(bool collapsed)
    {
        _navCollapsed = collapsed;
        return Task.CompletedTask;
    }
}
