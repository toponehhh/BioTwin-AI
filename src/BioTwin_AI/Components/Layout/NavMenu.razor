@using BioTwin_AI.Services
@implements IDisposable
@inject CurrentUserSession Session
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<div class="top-row navbar navbar-dark @(Collapsed ? "nav-collapsed" : "")">
    <div class="container-fluid">
        <a class="navbar-brand" href="" title="BioTwin_AI">
            <span class="brand-short">BT</span>
            <span class="nav-label">BioTwin_AI</span>
        </a>
        <button type="button"
                class="collapse-toggle"
                title="@(Collapsed ? L["ExpandNavigation"] : L["CollapseNavigation"])"
                @onclick="ToggleCollapsed">
            <span class="bi @(Collapsed ? "bi-chevron-right" : "bi-chevron-left")" aria-hidden="true"></span>
        </button>
    </div>
</div>

<input type="checkbox" title="@L["NavigationMenu"]" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (Session.IsAuthenticated)
        {
            <div class="nav-item px-3 text-white-50 small">
                @if (Session.IsInterviewer)
                {
                    <span class="nav-label">@L["InterviewerMode"]</span>
                    <span class="nav-mini" title="@L["InterviewerMode"]">I</span>
                }
                else
                {
                    <span class="nav-label">@L["CandidateLabel", Session.Username ?? string.Empty]</span>
                    <span class="nav-mini" title="@Session.Username">C</span>
                }
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="chat" Match="NavLinkMatch.All">
                    <span class="bi bi-chat-dots-fill" aria-hidden="true"></span><span class="nav-label">@L["AIChat"]</span>
                </NavLink>
            </div>
            
            @* Only show for candidates *@
            @if (Session.IsCandidate)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/upload">
                        <span class="bi bi-cloud-upload-fill" aria-hidden="true"></span><span class="nav-label">@L["ResumeUpload"]</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/edit">
                        <span class="bi bi-pencil-square" aria-hidden="true"></span><span class="nav-label">@L["ResumeEdit"]</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/export">
                        <span class="bi bi-download" aria-hidden="true"></span><span class="nav-label">@L["ExportResume"]</span>
                    </NavLink>
                </div>
            }
            
            <div class="nav-item px-3">
                <button class="btn btn-link nav-link text-start" @onclick="LogoutAsync">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span><span class="nav-label">@L["Logout"]</span>
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-person-circle" aria-hidden="true"></span><span class="nav-label">@L["Login"]</span>
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public EventCallback<bool> CollapsedChanged { get; set; }

    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        AuthService.Logout();
        await Session.ClearPersistedAsync(JS);
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private async Task ToggleCollapsed()
    {
        Collapsed = !Collapsed;
        await CollapsedChanged.InvokeAsync(Collapsed);
    }

    private void OnSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}

