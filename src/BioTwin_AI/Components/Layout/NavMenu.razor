@using BioTwin_AI.Services
@implements IDisposable
@inject CurrentUserSession Session
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BioTwin_AI</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (Session.IsAuthenticated)
        {
            <div class="nav-item px-3 text-white-50 small">
                @if (Session.IsInterviewer)
                {
                    <span>🔍 <strong>Interviewer Mode</strong></span>
                }
                else
                {
                    <span>Candidate: <strong>@Session.Username</strong></span>
                }
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="chat" Match="NavLinkMatch.All">
                    <span class="bi bi-chat-dots-fill" aria-hidden="true"></span> AI Chat
                </NavLink>
            </div>
            
            @* Only show for candidates *@
            @if (Session.IsCandidate)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/upload">
                        <span class="bi bi-cloud-upload-fill" aria-hidden="true"></span> Resume Upload
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/edit">
                        <span class="bi bi-pencil-square" aria-hidden="true"></span> Resume Edit
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="resume/export">
                        <span class="bi bi-download" aria-hidden="true"></span> Export Resume
                    </NavLink>
                </div>
            }
            
            <div class="nav-item px-3">
                <button class="btn btn-link nav-link text-start" @onclick="LogoutAsync">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-person-circle" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        AuthService.Logout();
        await Session.ClearPersistedAsync(JS);
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void OnSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}

