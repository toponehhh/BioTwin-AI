@page "/resume/upload"
@using BioTwin_AI.Services
@using BioTwin_AI.Models
@rendermode InteractiveServer
@inject ResumeUploadService UploadService
@inject NavigationManager Navigation
@inject BioTwin_AI.Services.CurrentUserSession Session
@inject IJSRuntime JS

@if (!_sessionResolved)
{
    <div class="container mt-5">
        <div class="alert alert-secondary">Loading session...</div>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <div class="container mt-5">
        <div class="alert alert-warning">Please sign in to upload resume sections.</div>
        <a class="btn btn-primary" href="/login">Go to Login</a>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
            <div>
                <h2 class="mb-1">Upload Resume</h2>
                <div class="text-muted small">Supported formats: PDF, DOCX, PPTX, HTML, TXT</div>
            </div>
            <a href="/chat" class="btn btn-secondary">Back to Chat</a>
        </div>

        <div class="row g-4 upload-workspace">
            <div class="col-lg-4">
                <div class="card upload-panel">
                    <div class="card-body">
                        <form @onsubmit="ConvertSelectedFileAsync" @onsubmit:preventDefault="true" novalidate>
                            <div class="mb-3">
                                <label for="title" class="form-label">Resume Title</label>
                                <input type="text" class="form-control" id="title" @bind="sectionTitle"
                                       placeholder="Used when the converted Markdown has no section headings" />
                            </div>

                            <div class="mb-3">
                                <label for="fileUpload" class="form-label">Select File</label>
                                <InputFile id="fileUpload" class="form-control" @ref="fileInput"
                                           accept=".pdf,.docx,.pptx,.html,.txt" OnChange="@HandleFileSelected" />
                            </div>

                            @if (!string.IsNullOrEmpty(selectedFileName))
                            {
                                <div class="alert alert-secondary" role="alert">
                                    Selected: <strong>@selectedFileName</strong>
                                </div>
                            }

                            @if (isUploading)
                            {
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Uploading...</span>
                                </div>
                                <p class="text-muted">Processing: @statusMessage</p>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-primary w-100" disabled="@isSaving">
                                    Convert to Markdown
                                </button>
                            }

                            @if (isSaving)
                            {
                                <div class="alert alert-secondary mt-3 d-flex align-items-center gap-3" role="status">
                                    <div class="spinner-border spinner-border-sm" aria-hidden="true"></div>
                                    <span>@statusMessage</span>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger mt-3" role="alert">
                                    @errorMessage
                                </div>
                            }

                            @if (uploadSuccess)
                            {
                                <div class="alert alert-success mt-3" role="alert">
                                    <strong>Success!</strong> Saved and indexed @savedSectionCount section@(savedSectionCount == 1 ? "" : "s").
                                </div>
                            }

                            @if (isDuplicateUpload)
                            {
                                <div class="alert alert-warning mt-3" role="alert">
                                    <strong>Already uploaded.</strong> @duplicateMessage
                                </div>
                            }
                        </form>
                    </div>
                </div>

                @if (convertedSections.Count > 0)
                {
                    <div class="section-tree-preview mt-3" aria-label="Detected Markdown section tree">
                        <div class="section-tree-title">Detected section tree</div>
                        @foreach (var section in convertedSections)
                        {
                            <div class="section-tree-item" style="padding-left: @(GetSectionTreeIndent(section))px">
                                <span class="section-tree-badge">H@(section.HeadingLevel)</span>
                                <span>@(section.Title)</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="col-lg-8">
                <div class="card markdown-panel">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
                            <div>
                                <h5 class="mb-1">Converted Markdown</h5>
                                <div class="text-muted small">@MarkdownPreviewSummary</div>
                            </div>
                            <button class="btn btn-primary" @onclick="SaveConvertedMarkdownAsync" disabled="@(isSaving || string.IsNullOrWhiteSpace(convertedMarkdown))">
                                @(isSaving ? "Saving..." : isDuplicateUpload ? "Update Sections & Re-index" : "Save Sections & Index")
                            </button>
                        </div>

                        <MarkdownEditor Value="@convertedMarkdown"
                                        ValueChanged="OnConvertedMarkdownChanged"
                                        Label="Markdown Content"
                                        Placeholder="Converted Markdown will appear here..."
                                        Rows="24" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .section-tree-preview {
        display: grid;
        gap: 6px;
        padding: 12px;
        border: 1px solid #d8dee8;
        border-radius: 8px;
        background: #f8fafc;
    }

    .section-tree-title {
        color: #475569;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .section-tree-item {
        display: flex;
        align-items: center;
        gap: 8px;
        min-height: 28px;
        color: #1f2937;
        font-size: 13px;
    }

    .section-tree-badge {
        min-width: 28px;
        padding: 2px 6px;
        border-radius: 6px;
        background: #eef2ff;
        color: #4754b8;
        font-size: 11px;
        font-weight: 800;
        text-align: center;
    }

    .upload-workspace {
        align-items: flex-start;
    }

    .upload-panel,
    .markdown-panel {
        border-radius: 8px;
    }
</style>

@code {
    private InputFile? fileInput;
    private string sectionTitle = "";
    private string selectedFileName = "";
    private bool isUploading = false;
    private bool isSaving = false;
    private string statusMessage = "";
    private string errorMessage = "";
    private bool uploadSuccess = false;
    private IBrowserFile? selectedFile;
    private string convertedMarkdown = "";
    private string convertedFileName = "";
    private string convertedContentType = "";
    private long? convertedFileSize;
    private byte[]? convertedFileBytes;
    private string convertedFileHash = "";
    private bool isDuplicateUpload;
    private int? existingResumeEntryId;
    private string duplicateMessage = "";
    private bool _sessionResolved;
    private int estimatedSectionCount = 1;
    private int savedSectionCount;
    private List<ResumeMarkdownSection> convertedSections = new();

    private string MarkdownPreviewSummary => isDuplicateUpload
        ? "This file is already saved. Edit the Markdown and update its sections when ready."
        : $"Review and edit the converted content. It will be saved as {estimatedSectionCount} section{(estimatedSectionCount == 1 ? "" : "s")} in a heading tree.";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        _sessionResolved = true;
        StateHasChanged();

        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File.Name;
        errorMessage = "";
        uploadSuccess = false;
        convertedMarkdown = "";
        convertedFileName = "";
        convertedContentType = "";
        convertedFileSize = null;
        convertedFileBytes = null;
        convertedFileHash = "";
        isDuplicateUpload = false;
        existingResumeEntryId = null;
        duplicateMessage = "";
        estimatedSectionCount = 1;
        savedSectionCount = 0;
        convertedSections.Clear();
        StateHasChanged();
    }

    private async Task ConvertSelectedFileAsync()
    {
        errorMessage = "";
        uploadSuccess = false;

        try
        {
            if (selectedFile == null)
            {
                errorMessage = "Please select a file";
                return;
            }

            isUploading = true;
            await UpdateStatusAsync("Preparing resume upload...");

            var convertedFile = await UploadService.ConvertResumeFileAsync(selectedFile, UpdateStatusAsync);
            convertedMarkdown = convertedFile.MarkdownContent;
            convertedFileName = convertedFile.FileName;
            convertedContentType = convertedFile.ContentType;
            convertedFileSize = convertedFile.Size;
            convertedFileBytes = convertedFile.FileBytes;
            convertedFileHash = convertedFile.FileHash;
            isDuplicateUpload = convertedFile.IsDuplicate;
            existingResumeEntryId = convertedFile.ExistingResumeEntryId;

            if (isDuplicateUpload && !string.IsNullOrWhiteSpace(convertedFile.ExistingResumeTitle))
            {
                sectionTitle = convertedFile.ExistingResumeTitle;
            }
            else if (string.IsNullOrWhiteSpace(sectionTitle))
            {
                sectionTitle = System.IO.Path.GetFileNameWithoutExtension(convertedFile.FileName);
            }

            UpdateConvertedSections();

            if (isDuplicateUpload)
            {
                duplicateMessage = $"The selected file matches existing resume #{existingResumeEntryId}. Its saved title and Markdown were loaded for editing.";
                await UpdateStatusAsync("Duplicate file detected. Existing resume was reused.");
            }
            else
            {
                await UpdateStatusAsync($"Markdown has been split into {estimatedSectionCount} section(s). Review it before saving.");
            }
        }
        catch (TaskCanceledException ex)
        {
            errorMessage = $"Conversion failed: All2MD conversion timed out. Details: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Conversion failed: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task SaveConvertedMarkdownAsync()
    {
        errorMessage = "";
        uploadSuccess = false;

        if (string.IsNullOrWhiteSpace(sectionTitle))
        {
            errorMessage = "Please enter a resume title";
            return;
        }

        if (string.IsNullOrWhiteSpace(convertedMarkdown))
        {
            errorMessage = "Markdown content is required.";
            return;
        }

        try
        {
            isSaving = true;
            await UpdateStatusAsync(isDuplicateUpload
                ? "Updating existing resume sections and rebuilding embeddings..."
                : "Splitting, saving, and indexing Markdown sections...");

            var savedEntries = isDuplicateUpload && existingResumeEntryId is not null
                ? await UploadService.ReplaceResumeMarkdownSectionsAsync(
                    existingResumeEntryId.Value,
                    sectionTitle,
                    convertedMarkdown,
                    UpdateStatusAsync)
                : await UploadService.SaveResumeMarkdownSectionsAsync(
                    sectionTitle,
                    convertedMarkdown,
                    convertedFileName,
                    convertedContentType,
                    convertedFileSize,
                    convertedFileBytes,
                    convertedFileHash,
                    UpdateStatusAsync);

            statusMessage = "";
            uploadSuccess = true;
            savedSectionCount = savedEntries.Count;
            selectedFileName = "";
            selectedFile = null;
            sectionTitle = "";
            convertedMarkdown = "";
            convertedFileName = "";
            convertedContentType = "";
            convertedFileSize = null;
            convertedFileBytes = null;
            convertedFileHash = "";
            isDuplicateUpload = false;
            existingResumeEntryId = null;
            duplicateMessage = "";
            estimatedSectionCount = 1;
            convertedSections.Clear();
            fileInput = null;

            await Task.Delay(1000);
            Navigation.NavigateTo("/chat");
        }
        catch (Exception ex)
        {
            errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private Task OnConvertedMarkdownChanged(string value)
    {
        convertedMarkdown = value;
        UpdateConvertedSections();
        return Task.CompletedTask;
    }

    private async Task UpdateStatusAsync(string message)
    {
        statusMessage = message;
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateConvertedSections()
    {
        convertedSections = ResumeUploadService.SplitResumeMarkdown(convertedMarkdown, sectionTitle);
        estimatedSectionCount = convertedSections.Count;
    }

    private static int GetSectionTreeIndent(ResumeMarkdownSection section)
    {
        var level = Math.Clamp(section.HeadingLevel, 1, 6);
        return (level - 1) * 18;
    }
}
