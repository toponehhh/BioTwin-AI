@page "/resume/export"
@using System.Text
@using BioTwin_AI.Data
@using BioTwin_AI.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject BioTwinDbContext DbContext
@inject CurrentUserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ResumePdfExportService PdfExportService

@if (!_sessionResolved)
{
    <div class="container mt-4">
        <div class="alert alert-secondary">Loading session...</div>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <div class="container mt-4">
        <div class="alert alert-warning">Please sign in first.</div>
        <a class="btn btn-primary" href="/login">Go to Login</a>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
            <div>
                <h2 class="mb-1">Export Resume</h2>
                <div class="text-muted small">Edit the generated Markdown before copying it out.</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary" @onclick="CopyAllAsync" disabled="@string.IsNullOrWhiteSpace(_markdown)">
                    Copy Markdown
                </button>
                <button class="btn btn-primary" @onclick="DownloadMarkdownAsync" disabled="@string.IsNullOrWhiteSpace(_markdown)">
                    Download Markdown
                </button>
                <button class="btn btn-outline-primary" @onclick="DownloadPdfAsync" disabled="@(string.IsNullOrWhiteSpace(_markdown) || _isExportingPdf)">
                    @(_isExportingPdf ? "Preparing PDF..." : "Download PDF")
                </button>
                <button class="btn btn-outline-primary" @onclick="DownloadOriginalFileAsync" disabled="@(_selectedResume?.HasOriginalFile != true)">
                    Download Original File
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert alert-success">@_message</div>
        }
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (_resumeOptions.Count == 0)
        {
            <div class="alert alert-info">No resumes found. Please upload content first.</div>
        }
        else
        {
            <div class="mb-3">
                <label for="resumeEntry" class="form-label">Resume to export</label>
                <select id="resumeEntry" class="form-select" value="@_selectedResumeEntryId" @onchange="OnResumeChangedAsync">
                    @foreach (var resume in _resumeOptions)
                    {
                        <option value="@resume.Id">@resume.Label</option>
                    }
                </select>
                @if (_selectedResume is not null)
                {
                    <div class="form-text">
                        @_selectedResume.SectionCount section@(_selectedResume.SectionCount == 1 ? "" : "s")
                        - uploaded @_selectedResume.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </div>
                }
            </div>

            @if (string.IsNullOrWhiteSpace(_markdown))
            {
                <div class="alert alert-info">No resume sections found for the selected resume.</div>
            }
            else
            {
                <MarkdownEditor Value="@_markdown"
                                ValueChanged="OnMarkdownChanged"
                                Label="Export Markdown"
                                Placeholder="Resume Markdown will appear here..."
                                Rows="22" />
            }
        }
    </div>
}

@code {
    private bool _sessionResolved;
    private bool _isExportingPdf;
    private string _markdown = string.Empty;
    private string _message = string.Empty;
    private string _error = string.Empty;
    private int? _selectedResumeEntryId;
    private List<ResumeExportOption> _resumeOptions = new();
    private ResumeExportOption? _selectedResume => _resumeOptions.FirstOrDefault(x => x.Id == _selectedResumeEntryId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        _sessionResolved = true;

        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadResumeOptionsAsync();
        StateHasChanged();
    }

    private async Task LoadResumeOptionsAsync()
    {
        var resumes = await DbContext.ResumeEntries
            .AsNoTracking()
            .Where(x => Session.IsInterviewer || x.TenantId == Session.Username)
            .OrderByDescending(x => x.CreatedAt)
            .Select(x => new
            {
                x.Id,
                x.Title,
                x.SourceFileName,
                x.SourceContentType,
                x.TenantId,
                x.CreatedAt,
                HasOriginalFile = x.SourceFileContent != null,
                SectionCount = x.Sections.Count
            })
            .ToListAsync();

        _resumeOptions = resumes
            .Select(x => new ResumeExportOption(
                x.Id,
                x.Title,
                x.SourceFileName,
                x.SourceContentType,
                BuildResumeLabel(x.Title, x.TenantId),
                x.CreatedAt,
                x.HasOriginalFile,
                x.SectionCount))
            .ToList();
        _selectedResumeEntryId = _resumeOptions.FirstOrDefault()?.Id;
        await LoadMarkdownAsync();
    }

    private async Task LoadMarkdownAsync()
    {
        if (_selectedResumeEntryId is null)
        {
            _markdown = string.Empty;
            return;
        }

        var sections = await DbContext.ResumeSections
            .AsNoTracking()
            .Where(x =>
                x.ResumeEntryId == _selectedResumeEntryId.Value &&
                (Session.IsInterviewer || x.TenantId == Session.Username))
            .OrderBy(x => x.SortOrder)
            .ToListAsync();

        if (sections.Count == 0)
        {
            _markdown = string.Empty;
            return;
        }

        var sb = new StringBuilder();
        sb.AppendLine($"# {GetSelectedResumeTitle()}");
        sb.AppendLine();

        foreach (var item in sections)
        {
            sb.AppendLine($"{new string('#', Math.Clamp(item.HeadingLevel, 1, 6))} {item.Title}");
            sb.AppendLine();
            sb.AppendLine(item.Content);
            sb.AppendLine();
        }

        _markdown = sb.ToString().Trim();
    }

    private async Task OnResumeChangedAsync(ChangeEventArgs args)
    {
        _message = string.Empty;

        if (int.TryParse(args.Value?.ToString(), out var resumeEntryId))
        {
            _selectedResumeEntryId = resumeEntryId;
            await LoadMarkdownAsync();
        }
    }

    private async Task CopyAllAsync()
    {
        _message = string.Empty;
        _error = string.Empty;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _markdown);
        _message = "Markdown copied to clipboard.";
    }

    private async Task DownloadMarkdownAsync()
    {
        _message = string.Empty;
        _error = string.Empty;
        var fileName = $"{BuildSafeFileName(GetSelectedResumeTitle())}.md";
        await DownloadBytesAsync(fileName, "text/markdown;charset=utf-8", Encoding.UTF8.GetBytes(_markdown));
        _message = "Markdown download started.";
    }

    private async Task DownloadPdfAsync()
    {
        _message = string.Empty;
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(_markdown))
        {
            _error = "Markdown content is required before exporting PDF.";
            return;
        }

        try
        {
            _isExportingPdf = true;
            var fileName = $"{BuildSafeFileName(GetSelectedResumeTitle())}.pdf";
            var pdfBytes = await Task.Run(() => PdfExportService.GeneratePdf(_markdown, GetSelectedResumeTitle()));
            await DownloadBytesAsync(fileName, "application/pdf", pdfBytes);
            _message = "PDF download started.";
        }
        catch (Exception ex)
        {
            _error = $"Failed to export PDF: {ex.Message}";
        }
        finally
        {
            _isExportingPdf = false;
        }
    }

    private async Task DownloadOriginalFileAsync()
    {
        _message = string.Empty;
        _error = string.Empty;

        if (_selectedResumeEntryId is null)
        {
            return;
        }

        var originalFile = await DbContext.ResumeEntries
            .AsNoTracking()
            .Where(x =>
                x.Id == _selectedResumeEntryId.Value &&
                (Session.IsInterviewer || x.TenantId == Session.Username))
            .Select(x => new
            {
                x.SourceFileName,
                x.SourceContentType,
                x.SourceFileContent
            })
            .FirstOrDefaultAsync();

        if (originalFile?.SourceFileContent is not { Length: > 0 } fileBytes)
        {
            _message = "No original uploaded file is stored for this resume.";
            return;
        }

        var fileName = string.IsNullOrWhiteSpace(originalFile.SourceFileName)
            ? $"{BuildSafeFileName(GetSelectedResumeTitle())}.bin"
            : originalFile.SourceFileName;
        var contentType = string.IsNullOrWhiteSpace(originalFile.SourceContentType)
            ? "application/octet-stream"
            : originalFile.SourceContentType;

        await DownloadBytesAsync(fileName, contentType, fileBytes);
        _message = "Original file download started.";
    }

    private async Task DownloadBytesAsync(string fileName, string contentType, byte[] fileBytes)
    {
        using var stream = new MemoryStream(fileBytes);
        using var streamReference = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("bioTwinDownloads.downloadFileFromStream", fileName, contentType, streamReference);
    }

    private Task OnMarkdownChanged(string value)
    {
        _markdown = value;
        _message = string.Empty;
        _error = string.Empty;
        return Task.CompletedTask;
    }

    private string GetSelectedResumeTitle()
    {
        return _selectedResume?.Title ?? "Resume";
    }

    private string BuildResumeLabel(string title, string tenantId)
    {
        var label = string.IsNullOrWhiteSpace(title) ? "Untitled resume" : title;
        return Session.IsInterviewer ? $"{label} ({tenantId})" : label;
    }

    private static string BuildSafeFileName(string value)
    {
        var safeName = string.Join("_", value.Split(Path.GetInvalidFileNameChars(), StringSplitOptions.RemoveEmptyEntries)).Trim();
        return string.IsNullOrWhiteSpace(safeName) ? "resume" : safeName;
    }

    private sealed record ResumeExportOption(
        int Id,
        string Title,
        string SourceFileName,
        string? SourceContentType,
        string Label,
        DateTime CreatedAt,
        bool HasOriginalFile,
        int SectionCount);
}
