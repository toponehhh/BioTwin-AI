@page "/login"
@using BioTwin_AI.Services
@rendermode InteractiveServer
@inject AuthService AuthService
@inject CurrentUserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-container">
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <h2 class="login-title">BioTwin</h2>
                <p class="login-subtitle">AI Interview Assistant</p>
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert-custom @(isError ? "alert-danger" : "alert-success")">
                    <span class="alert-icon">@(isError ? "⚠" : "✓")</span>
                    <span>@message</span>
                </div>
            }

            <div class="mode-switcher">
                <button class="mode-btn @(!isRegister && !isInterviewer ? "active" : "")" @onclick="() => { isRegister = false; isInterviewer = false; }">
                    <span class="mode-icon">→</span>
                    <span>Sign In</span>
                </button>
                <button class="mode-btn @(isRegister && !isInterviewer ? "active" : "")" @onclick="() => { isRegister = true; isInterviewer = false; }">
                    <span class="mode-icon">+</span>
                    <span>Register</span>
                </button>
                <button class="mode-btn @(isInterviewer ? "active" : "")" @onclick="() => { isInterviewer = true; isRegister = false; }">
                    <span class="mode-icon">🔍</span>
                    <span>Interviewer</span>
                </button>
            </div>

            @if (!isInterviewer)
            {
                <EditForm Model="loginModel" OnValidSubmit="HandleSubmit">
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input class="form-input" @bind="loginModel.Username" placeholder="Enter username" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input class="form-input" type="password" @bind="loginModel.Password" placeholder="Enter password" required />
                    </div>
                    <button class="btn-submit" type="submit">
                        @(isRegister ? "Create Account" : "Sign In")
                    </button>
                </EditForm>
            }
            else
            {
                <div class="interviewer-info">
                    <div class="info-icon">🔍</div>
                    <h3>Interview Mode</h3>
                    <p>Browse and search all candidate resumes</p>
                    <button class="btn-submit" @onclick="HandleInterviewerLogin">
                        Enter as Interviewer
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
.login-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    position: relative;
    overflow: hidden;
    padding: 20px;
}

.login-container::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: drift 20s linear infinite;
}

@@keyframes drift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
}

.login-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    padding: 20px;
}

.login-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 24px;
    padding: 48px 32px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@@keyframes popIn {
    0% {
        opacity: 0;
        transform: scale(0.8);
    }
    100% {
        opacity: 1;
        transform: scale(1);
    }
}

.login-header {
    text-align: center;
    margin-bottom: 32px;
}

.login-title {
    font-size: 32px;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 8px 0;
}

.login-subtitle {
    color: #86868b;
    font-size: 14px;
    margin: 0;
    font-weight: 500;
}

.alert-custom {
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    animation: slideDown 0.3s ease;
}

@@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-custom.alert-danger {
    background: rgba(255, 68, 88, 0.1);
    color: #ff4458;
}

.alert-custom.alert-success {
    background: rgba(0, 208, 132, 0.1);
    color: #00d084;
}

.alert-icon {
    font-weight: bold;
}

.mode-switcher {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
}

.mode-btn {
    flex: 1;
    padding: 12px 16px;
    border: none;
    border-radius: 12px;
    background: #f5f5f7;
    color: #86868b;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.mode-btn:hover {
    background: #e8e8ed;
}

.mode-btn.active {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3);
}

.mode-icon {
    font-weight: bold;
}

.form-group {
    margin-bottom: 20px;
}

.form-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 8px;
}

.form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #d5d5d7;
    border-radius: 12px;
    font-size: 14px;
    background: #f5f5f7;
    color: #1d1d1f;
    transition: all 0.3s ease;
    box-sizing: border-box;
}

.form-input:focus {
    outline: none;
    background: white;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-input::placeholder {
    color: #a1a1a6;
}

.btn-submit {
    width: 100%;
    padding: 14px 24px;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3);
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(102, 126, 234, 0.4);
}

.btn-submit:active {
    transform: translateY(0);
}

.interviewer-info {
    text-align: center;
    padding: 20px;
    background: rgba(0, 212, 255, 0.1);
    border-radius: 12px;
    border: 1px solid rgba(0, 212, 255, 0.2);
}

.info-icon {
    font-size: 48px;
    margin-bottom: 12px;
    display: block;
}

.interviewer-info h3 {
    margin: 12px 0 8px 0;
    font-size: 18px;
    color: #1d1d1f;
}

.interviewer-info p {
    margin: 0 0 20px 0;
    font-size: 13px;
    color: #86868b;
}
</style>

@code {
    private readonly LoginModel loginModel = new();
    private string message = string.Empty;
    private bool isError;
    private bool isRegister;
    private bool isInterviewer;

    private sealed class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        if (Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/chat");
        }
    }

    private async Task HandleSubmit()
    {
        (bool Success, string Message) result;

        if (isRegister)
        {
            result = await AuthService.RegisterAsync(loginModel.Username, loginModel.Password);
        }
        else
        {
            result = await AuthService.LoginAsync(loginModel.Username, loginModel.Password);
        }

        isError = !result.Success;
        message = result.Message;

        if (result.Success)
        {
            await Session.PersistAsync(JS);
            Navigation.NavigateTo("/chat");
        }
    }

    private async Task HandleInterviewerLogin()
    {
        Session.InterviewerLogin();
        await Session.PersistAsync(JS);
        Navigation.NavigateTo("/chat");
    }
}
