@page "/resume/edit"
@using BioTwin_AI.Data
@using BioTwin_AI.Models
@using BioTwin_AI.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject BioTwinDbContext DbContext
@inject IRagService RagService
@inject CurrentUserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!_sessionResolved)
{
    <div class="container mt-4">
        <div class="alert alert-secondary">Loading session...</div>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <div class="container mt-4">
        <div class="alert alert-warning">Please sign in first.</div>
        <a class="btn btn-primary" href="/login">Go to Login</a>
    </div>
}
else
{
    <div class="resume-builder">
        <aside class="section-sidebar">
            <div class="section-sidebar-header">
                <div>
                    <h2>Resume Builder</h2>
                    <span>@_resumeEntries.Count resume@(_resumeEntries.Count == 1 ? "" : "s") - @_entries.Count section@(_entries.Count == 1 ? "" : "s")</span>
                </div>
                <button class="icon-action" title="Add section" @onclick="CreateSection">
                    +
                </button>
            </div>

            <div class="section-actions">
                <button class="btn btn-primary" @onclick="CreateSection">New Section</button>
                <a class="btn btn-outline-primary" href="/resume/upload">Upload File</a>
            </div>

            @if (_resumeEntries.Count > 0)
            {
                <div class="resume-picker">
                    <div class="sidebar-kicker">Resume</div>
                    <select class="form-select resume-select"
                            aria-label="Select resume"
                            value="@GetSelectedResumeIndex()"
                            @onchange="OnResumeChanged">
                        @for (var index = 0; index < _resumeEntries.Count; index++)
                        {
                            var resume = _resumeEntries[index];
                            <option value="@index">@GetResumeTitle(resume) (@GetResumeSummary(resume))</option>
                        }
                    </select>
                </div>
            }

            @if (_resumeEntries.Count == 0)
            {
                <div class="empty-sections">
                    <strong>No resumes yet</strong>
                    <span>Upload a resume file or create a manual section to get started.</span>
                </div>
            }
            else if (_selectedResumeEntry is null)
            {
                <div class="empty-sections">
                    <strong>Select a resume</strong>
                    <span>Choose which resume you want to edit.</span>
                </div>
            }
            else if (_entries.Count == 0)
            {
                <div class="empty-sections">
                    <strong>No sections in this resume</strong>
                    <span>Create a section for @GetResumeTitle(_selectedResumeEntry).</span>
                </div>
            }
            else
            {
                <div class="sidebar-kicker">Sections</div>
                <div class="section-list" role="list" aria-label="Resume sections">
                    @foreach (var entry in _entries)
                    {
                        <button type="button"
                                class="section-list-item @(ReferenceEquals(_selectedEntry, entry) ? "active" : "")"
                                style="padding-left: @(GetTreeIndent(entry))px"
                                @onclick="() => SelectEntry(entry)">
                            <span class="section-title">
                                <span class="heading-level-badge">H@entry.HeadingLevel</span>
                                @entry.Title
                            </span>
                            <span class="section-meta">@GetEntrySummary(entry)</span>
                        </button>
                    }
                </div>
            }
        </aside>

        <main class="section-editor">
            <div class="editor-topbar">
                <a class="btn btn-secondary" href="/chat">Back to Chat</a>
                <div class="editor-actions">
                    @if (_selectedEntry is not null)
                    {
                        <button class="btn btn-outline-secondary" @onclick="DuplicateSelectedAsync" disabled="@_isSaving">Duplicate</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteSelectedAsync" disabled="@_isSaving">Delete</button>
                        <button class="btn btn-primary" @onclick="SaveSelectedAsync" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save Section")
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="alert alert-success">@_message</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            @if (_selectedEntry is null)
            {
                <div class="editor-empty-state">
                    <h3>@(_selectedResumeEntry is null ? "Select a resume" : "Select a section")</h3>
                    <p>@(_selectedResumeEntry is null ? "Choose a resume file from the left panel before editing sections." : "Choose a section from the left panel or create a new one.")</p>
                    <button class="btn btn-primary" @onclick="CreateSection">Create Section</button>
                </div>
            }
            else
            {
                <section class="section-workspace">
                    <div class="builder-workspace-grid">
                        <div class="section-edit-pane">
                            <div class="section-meta-row">
                                <span>@(_selectedEntry.Id == 0 ? "Draft section" : $"Created {_selectedEntry.CreatedAt.ToLocalTime():yyyy-MM-dd HH:mm}")</span>
                                <span>@GetWordCount(_selectedEntry.Content) words</span>
                                <span>Editing @GetResumeTitle(_selectedResumeEntry ?? _selectedEntry.ResumeEntry)</span>
                                @if (!string.IsNullOrWhiteSpace(GetSourceFileName(_selectedEntry)) && GetSourceFileName(_selectedEntry) != ManualSourceName)
                                {
                                    <span>Imported from @GetSourceFileName(_selectedEntry)</span>
                                }
                            </div>

                            <MarkdownEditor @bind-Value="_selectedEntry.Content"
                                            Label="Markdown"
                                            Placeholder="Write this resume section in Markdown..."
                                            Rows="22" />
                        </div>
                    </div>
                </section>
            }
        </main>
    </div>
}

