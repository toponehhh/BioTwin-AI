@code {
    private const string ManualSourceName = "Manual section";

    private sealed record SectionTreeNode(ResumeSection Entry, int Depth, bool HasChildren);

    private readonly List<ResumeEntry> _resumeEntries = [];
    private readonly List<ResumeSection> _entries = [];
    private readonly HashSet<string> _collapsedSectionKeys = [];
    private ResumeEntry? _selectedResumeEntry;
    private ResumeSection? _selectedEntry;
    private MarkdownEditor? _fullResumeEditor;
    private bool _sessionResolved;
    private bool _isSaving;
    private string _wholeResumeMarkdown = string.Empty;
    private string _message = string.Empty;
    private string _error = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.RestoreAsync(JS);
        _sessionResolved = true;

        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadEntriesAsync();
        StateHasChanged();
    }

    private async Task LoadEntriesAsync()
    {
        _resumeEntries.Clear();
        _entries.Clear();
        _selectedResumeEntry = null;
        _selectedEntry = null;
        _wholeResumeMarkdown = string.Empty;

        var itemsQuery = DbContext.ResumeEntries
            .Include(x => x.Sections)
            .AsQueryable();
        if (!Session.IsInterviewer)
        {
            itemsQuery = itemsQuery.Where(x => x.TenantId == Session.Username);
        }

        var items = await itemsQuery
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync();

        _resumeEntries.AddRange(items);
        SelectResume(_resumeEntries.FirstOrDefault());
    }

    private void SelectResume(ResumeEntry? resumeEntry)
    {
        _message = string.Empty;
        _error = string.Empty;
        _selectedResumeEntry = resumeEntry;
        _selectedEntry = null;
        _entries.Clear();
        _collapsedSectionKeys.Clear();

        if (resumeEntry is null)
        {
            return;
        }

        var sections = resumeEntry.Sections
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id)
            .ToList();

        foreach (var section in sections)
        {
            section.ResumeEntry = resumeEntry;
        }

        _entries.AddRange(sections);
        _selectedEntry = _entries.FirstOrDefault();
        RefreshWholeResumeMarkdown();
    }

    private void OnResumeChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var index) ||
            index < 0 ||
            index >= _resumeEntries.Count)
        {
            SelectResume(null);
            return;
        }

        SelectResume(_resumeEntries[index]);
    }

    private int GetSelectedResumeIndex()
    {
        if (_selectedResumeEntry is null)
        {
            return 0;
        }

        var index = _resumeEntries.IndexOf(_selectedResumeEntry);
        return index < 0 ? 0 : index;
    }

    private async Task LocateSectionAsync(ResumeSection entry)
    {
        _message = string.Empty;
        _error = string.Empty;
        _selectedEntry = entry;

        if (_fullResumeEditor is null)
        {
            return;
        }

        await _fullResumeEditor.FocusLineAsync(FindSectionHeadingLine(entry));
    }

    private void CreateResumeDraft()
    {
        _message = string.Empty;
        _error = string.Empty;

        var targetResume = new ResumeEntry
        {
            Title = "Manual Resume",
            SourceFileName = ManualSourceName,
            CreatedAt = DateTime.UtcNow,
            TenantId = Session.Username ?? "default"
        };

        var draft = new ResumeSection
        {
            Title = "Untitled Resume",
            Content = "Add the resume content here.",
            HeadingLevel = 1,
            ResumeEntryId = targetResume.Id,
            ResumeEntry = targetResume,
            SortOrder = 0,
            CreatedAt = DateTime.UtcNow,
            TenantId = targetResume.TenantId
        };

        _selectedResumeEntry = targetResume;
        _selectedEntry = draft;
        _entries.Clear();
        _entries.Add(draft);
        _collapsedSectionKeys.Clear();
        _resumeEntries.Insert(0, targetResume);
        targetResume.Sections.Add(draft);
        RefreshWholeResumeMarkdown();
    }

    private async Task SaveSelectedAsync()
    {
        if (_selectedEntry is null)
        {
            return;
        }

        _message = string.Empty;
        _error = string.Empty;

        SyncSelectedTitleFromMarkdown();

        try
        {
            _isSaving = true;
            _selectedEntry.HeadingLevel = Math.Clamp(_selectedEntry.HeadingLevel, 1, 6);

            if (_selectedEntry.Id == 0)
            {
                _selectedEntry.CreatedAt = DateTime.UtcNow;
                _selectedEntry.TenantId = _selectedResumeEntry?.TenantId ?? Session.Username ?? "default";

                if (_selectedResumeEntry is not null)
                {
                    _selectedEntry.ResumeEntry = _selectedResumeEntry;
                    _selectedEntry.ResumeEntryId = _selectedResumeEntry.Id;
                    if (!_selectedResumeEntry.Sections.Contains(_selectedEntry))
                    {
                        _selectedResumeEntry.Sections.Add(_selectedEntry);
                    }
                }

                if (_selectedEntry.ResumeEntry is null)
                {
                    _selectedEntry.ResumeEntry = new ResumeEntry
                    {
                        Title = "Manual Resume",
                        SourceFileName = ManualSourceName,
                        CreatedAt = _selectedEntry.CreatedAt,
                        TenantId = _selectedEntry.TenantId
                    };
                }

                DbContext.ResumeSections.Add(_selectedEntry);
                await DbContext.SaveChangesAsync();

                if (_selectedResumeEntry is null)
                {
                    _selectedResumeEntry = _selectedEntry.ResumeEntry;
                    if (_selectedResumeEntry is not null && !_resumeEntries.Contains(_selectedResumeEntry))
                    {
                        _resumeEntries.Insert(0, _selectedResumeEntry);
                    }
                }
            }

            _selectedEntry.EmbeddingPayload = await CreateEmbeddingPayloadAsync(_selectedEntry);
            await DbContext.SaveChangesAsync();

            SortCurrentSections();
            RefreshWholeResumeMarkdown();
            _message = $"Saved section '{_selectedEntry.Title}'.";
        }
        catch (Exception ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DuplicateSelectedAsync()
    {
        if (_selectedEntry is null)
        {
            return;
        }

        var targetResume = _selectedResumeEntry ?? _selectedEntry.ResumeEntry;
        if (targetResume is null)
        {
            _error = "Select a resume before duplicating a section.";
            return;
        }

        var duplicate = new ResumeSection
        {
            Title = $"{_selectedEntry.Title} Copy",
            Content = _selectedEntry.Content,
            ResumeEntryId = targetResume.Id,
            ResumeEntry = targetResume,
            ParentSectionId = _selectedEntry.ParentSectionId,
            HeadingLevel = _selectedEntry.HeadingLevel,
            SortOrder = _entries.Count == 0 ? 0 : _entries.Max(entry => entry.SortOrder) + 1,
            CreatedAt = DateTime.UtcNow,
            TenantId = targetResume.TenantId
        };

        _entries.Insert(0, duplicate);
        targetResume.Sections.Add(duplicate);
        _selectedEntry = duplicate;
        RefreshWholeResumeMarkdown();
        await Task.CompletedTask;
    }

    private async Task DeleteSelectedAsync()
    {
        if (_selectedEntry is null)
        {
            return;
        }

        _message = string.Empty;
        _error = string.Empty;

        var entry = _selectedEntry;

        if (entry.Id != 0)
        {
            var resumeEntryId = entry.ResumeEntryId;
            var children = await DbContext.ResumeSections
                .Where(section => section.ParentSectionId == entry.Id)
                .ToListAsync();
            foreach (var child in children)
            {
                child.ParentSectionId = null;
            }

            DbContext.ResumeSections.Remove(entry);
            await DbContext.SaveChangesAsync();

            if (resumeEntryId != 0 && !await DbContext.ResumeSections.AnyAsync(section => section.ResumeEntryId == resumeEntryId))
            {
                var sourceEntry = await DbContext.ResumeEntries.FindAsync(resumeEntryId);
                if (sourceEntry is not null)
                {
                    DbContext.ResumeEntries.Remove(sourceEntry);
                    await DbContext.SaveChangesAsync();
                    _resumeEntries.RemoveAll(resume => resume.Id == resumeEntryId);
                }
            }
        }

        entry.ResumeEntry?.Sections.Remove(entry);
        _entries.Remove(entry);
        if (_selectedResumeEntry is not null && _selectedResumeEntry.Id == 0 && _selectedResumeEntry.Sections.Count == 0)
        {
            _resumeEntries.Remove(_selectedResumeEntry);
            SelectResume(_resumeEntries.FirstOrDefault());
        }
        else if (_selectedResumeEntry is not null && !_resumeEntries.Contains(_selectedResumeEntry))
        {
            SelectResume(_resumeEntries.FirstOrDefault());
        }
        else
        {
            _selectedEntry = _entries.FirstOrDefault();
        }

        _message = "Section deleted.";
        RefreshWholeResumeMarkdown();
    }

    private async Task SaveWholeResumeAsync()
    {
        if (_selectedResumeEntry is null)
        {
            _error = "Select a resume before saving the full Markdown.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_wholeResumeMarkdown))
        {
            _error = "Full resume Markdown is required.";
            return;
        }

        _message = string.Empty;
        _error = string.Empty;

        try
        {
            _isSaving = true;
            var resumeEntry = _selectedResumeEntry;
            var tenantId = string.IsNullOrWhiteSpace(resumeEntry.TenantId)
                ? Session.Username ?? "default"
                : resumeEntry.TenantId;

            if (resumeEntry.Id == 0)
            {
                resumeEntry.TenantId = tenantId;
                DbContext.ResumeEntries.Add(resumeEntry);
                await DbContext.SaveChangesAsync();
            }

            var parsedSections = ResumeUploadService.SplitResumeMarkdown(
                _wholeResumeMarkdown,
                GetResumeTitle(resumeEntry));
            var createdAt = DateTime.UtcNow;

            var existingSections = await DbContext.ResumeSections
                .Where(section => section.ResumeEntryId == resumeEntry.Id && section.TenantId == tenantId)
                .ToListAsync();
            DbContext.ResumeSections.RemoveRange(existingSections);
            await DbContext.SaveChangesAsync();

            resumeEntry.Sections.Clear();
            _entries.Clear();
            _collapsedSectionKeys.Clear();

            var sectionEntries = parsedSections
                .Select((section, index) => new ResumeSection
                {
                    ResumeEntryId = resumeEntry.Id,
                    ResumeEntry = resumeEntry,
                    Title = section.Title,
                    Content = section.Content,
                    HeadingLevel = section.HeadingLevel,
                    SortOrder = index,
                    CreatedAt = createdAt.AddTicks(index),
                    TenantId = tenantId
                })
                .ToList();

            DbContext.ResumeSections.AddRange(sectionEntries);
            await DbContext.SaveChangesAsync();

            for (var i = 0; i < parsedSections.Count; i++)
            {
                var parentIndex = parsedSections[i].ParentIndex;
                if (parentIndex is not null && parentIndex.Value >= 0 && parentIndex.Value < sectionEntries.Count)
                {
                    sectionEntries[i].ParentSectionId = sectionEntries[parentIndex.Value].Id;
                }
            }

            foreach (var sectionEntry in sectionEntries)
            {
                sectionEntry.EmbeddingPayload = await CreateEmbeddingPayloadAsync(sectionEntry);
            }

            await DbContext.SaveChangesAsync();

            foreach (var section in sectionEntries)
            {
                section.ResumeEntry = resumeEntry;
            }

            resumeEntry.Sections.Clear();
            foreach (var section in sectionEntries)
            {
                resumeEntry.Sections.Add(section);
            }

            _entries.AddRange(sectionEntries);
            _selectedEntry = _entries.FirstOrDefault();
            RefreshWholeResumeMarkdown();
            _message = $"Saved full resume and rebuilt {_entries.Count} section{(_entries.Count == 1 ? "" : "s")}.";
        }
        catch (Exception ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task<string> CreateEmbeddingPayloadAsync(ResumeSection entry)
    {
        return RagService.CreateEmbeddingPayloadAsync(
            entry.Content,
            new Dictionary<string, string>
            {
                { "title", entry.Title },
                { "content", entry.Content },
                { "db_id", entry.Id.ToString() },
                { "resume_entry_id", entry.ResumeEntryId.ToString() },
                { "source_file", GetSourceFileName(entry) },
                { "tenant_id", entry.TenantId }
            });
    }

    private IReadOnlyList<SectionTreeNode> GetVisibleSectionNodes()
    {
        var orderedEntries = _entries
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id)
            .ToList();
        var entriesById = orderedEntries
            .Where(section => section.Id != 0)
            .ToDictionary(section => section.Id);
        var childrenByParentId = orderedEntries
            .Where(section => section.ParentSectionId is not null && entriesById.ContainsKey(section.ParentSectionId.Value))
            .GroupBy(section => section.ParentSectionId!.Value)
            .ToDictionary(group => group.Key, group => group.ToList());
        var roots = orderedEntries
            .Where(section => section.ParentSectionId is null || !entriesById.ContainsKey(section.ParentSectionId.Value))
            .ToList();
        var visibleNodes = new List<SectionTreeNode>();
        var visitedKeys = new HashSet<string>();

        foreach (var root in roots)
        {
            AddVisibleSectionNode(root, 0);
        }

        foreach (var entry in orderedEntries)
        {
            AddVisibleSectionNode(entry, 0);
        }

        return visibleNodes;

        void AddVisibleSectionNode(ResumeSection entry, int depth)
        {
            var key = GetSectionKey(entry);
            if (!visitedKeys.Add(key))
            {
                return;
            }

            var children = entry.Id != 0 && childrenByParentId.TryGetValue(entry.Id, out var childItems)
                ? childItems
                : [];
            visibleNodes.Add(new SectionTreeNode(entry, depth, children.Count > 0));

            if (children.Count == 0 || IsSectionCollapsed(entry))
            {
                return;
            }

            foreach (var child in children)
            {
                AddVisibleSectionNode(child, depth + 1);
            }
        }
    }

    private void ToggleSectionNode(ResumeSection entry)
    {
        var key = GetSectionKey(entry);
        if (!_collapsedSectionKeys.Add(key))
        {
            _collapsedSectionKeys.Remove(key);
        }
    }

    private bool IsSectionCollapsed(ResumeSection entry)
    {
        return _collapsedSectionKeys.Contains(GetSectionKey(entry));
    }

    private static string GetSectionDisplayTitle(ResumeSection entry)
    {
        return string.IsNullOrWhiteSpace(entry.Title)
            ? "Untitled Section"
            : entry.Title.Trim();
    }

    private string? GetSectionAriaExpanded(SectionTreeNode node)
    {
        return node.HasChildren
            ? (!IsSectionCollapsed(node.Entry)).ToString().ToLowerInvariant()
            : null;
    }

    private static string GetSectionKey(ResumeSection entry)
    {
        return entry.Id != 0
            ? $"id:{entry.Id}"
            : $"draft:{System.Runtime.CompilerServices.RuntimeHelpers.GetHashCode(entry)}";
    }

    private void RefreshWholeResumeMarkdown()
    {
        _wholeResumeMarkdown = BuildResumeMarkdown(_entries);
    }

    private int FindSectionHeadingLine(ResumeSection entry)
    {
        var normalizedMarkdown = (_wholeResumeMarkdown ?? string.Empty)
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n');
        var lines = normalizedMarkdown.Split('\n');
        var targetTitle = GetSectionDisplayTitle(entry);
        var targetHeadingLevel = Math.Clamp(entry.HeadingLevel, 1, 6);
        var orderedEntries = _entries
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id)
            .ToList();
        var sameHeadingOrdinal = orderedEntries
            .TakeWhile(section => !ReferenceEquals(section, entry))
            .Count(section =>
                Math.Clamp(section.HeadingLevel, 1, 6) == targetHeadingLevel &&
                string.Equals(GetSectionDisplayTitle(section), targetTitle, StringComparison.OrdinalIgnoreCase));

        var matchingHeadingOrdinal = 0;
        var headingLineIndexes = new List<int>();
        var titleOnlyLineIndex = -1;

        for (var index = 0; index < lines.Length; index++)
        {
            if (!TryParseMarkdownHeading(lines[index], out var title, out var headingLevel))
            {
                continue;
            }

            headingLineIndexes.Add(index);

            if (!string.Equals(title, targetTitle, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (titleOnlyLineIndex < 0)
            {
                titleOnlyLineIndex = index;
            }

            if (headingLevel != targetHeadingLevel)
            {
                continue;
            }

            if (matchingHeadingOrdinal == sameHeadingOrdinal)
            {
                return index;
            }

            matchingHeadingOrdinal++;
        }

        if (titleOnlyLineIndex >= 0)
        {
            return titleOnlyLineIndex;
        }

        var sectionIndex = orderedEntries.FindIndex(section => ReferenceEquals(section, entry));
        if (sectionIndex >= 0 && headingLineIndexes.Count > 0)
        {
            return headingLineIndexes[Math.Min(sectionIndex, headingLineIndexes.Count - 1)];
        }

        return 0;
    }

    private static string BuildResumeMarkdown(IEnumerable<ResumeSection> sections)
    {
        var builder = new StringBuilder();

        foreach (var section in sections
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id))
        {
            var headingLevel = Math.Clamp(section.HeadingLevel, 1, 6);
            var title = string.IsNullOrWhiteSpace(section.Title)
                ? "Untitled Section"
                : section.Title.Trim();

            builder.AppendLine($"{new string('#', headingLevel)} {title}");

            if (!string.IsNullOrWhiteSpace(section.Content))
            {
                builder.AppendLine();
                builder.AppendLine(section.Content.Trim());
            }

            builder.AppendLine();
        }

        return builder.ToString().Trim();
    }

    private static string GetEntrySummary(ResumeSection entry)
    {
        var source = string.IsNullOrWhiteSpace(GetSourceFileName(entry))
            ? ManualSourceName
            : GetSourceFileName(entry);

        return source == ManualSourceName
            ? $"{GetWordCount(entry.Content)} words"
            : $"{source} - {GetWordCount(entry.Content)} words";
    }

    private static int GetWordCount(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return 0;
        }

        return text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    private static string GetSourceFileName(ResumeSection entry)
    {
        return entry.ResumeEntry?.SourceFileName ?? string.Empty;
    }

    private static string GetResumeTitle(ResumeEntry? resumeEntry)
    {
        if (resumeEntry is null)
        {
            return "No resume selected";
        }

        if (!string.IsNullOrWhiteSpace(resumeEntry.Title))
        {
            return resumeEntry.Title.Trim();
        }

        var primaryTitle = resumeEntry.Sections
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id)
            .FirstOrDefault(section => section.HeadingLevel == 1 && !string.IsNullOrWhiteSpace(section.Title))
            ?.Title;

        if (!string.IsNullOrWhiteSpace(primaryTitle))
        {
            return primaryTitle.Trim();
        }

        var firstSectionTitle = resumeEntry.Sections
            .OrderBy(section => section.SortOrder)
            .ThenBy(section => section.Id)
            .FirstOrDefault(section => !string.IsNullOrWhiteSpace(section.Title))
            ?.Title;

        if (!string.IsNullOrWhiteSpace(firstSectionTitle))
        {
            return firstSectionTitle.Trim();
        }

        return resumeEntry.SourceFileName == ManualSourceName
            ? "Manual Resume"
            : $"Resume {resumeEntry.CreatedAt.ToLocalTime():yyyy-MM-dd HH:mm}";
    }

    private static string GetResumeSummary(ResumeEntry resumeEntry)
    {
        var sectionCount = resumeEntry.Sections.Count;
        var created = resumeEntry.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
        return $"{sectionCount} section{(sectionCount == 1 ? "" : "s")} - {created}";
    }

    private void SyncSelectedTitleFromMarkdown()
    {
        if (_selectedEntry is null)
        {
            return;
        }

        var normalized = NormalizeSectionMarkdown(
            _selectedEntry.Content,
            _selectedEntry.Title,
            _selectedEntry.HeadingLevel);

        _selectedEntry.Title = normalized.Title;
        _selectedEntry.HeadingLevel = normalized.HeadingLevel;
        _selectedEntry.Content = normalized.Content;
    }

    private static (string Title, int HeadingLevel, string Content) NormalizeSectionMarkdown(
        string? content,
        string? fallbackTitle,
        int fallbackHeadingLevel)
    {
        var normalizedContent = (content ?? string.Empty)
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n');
        var lines = normalizedContent.Split('\n').ToList();

        for (var index = 0; index < lines.Count; index++)
        {
            var line = lines[index];
            if (string.IsNullOrWhiteSpace(line))
            {
                continue;
            }

            if (!TryParseMarkdownHeading(line, out var title, out var headingLevel))
            {
                break;
            }

            lines.RemoveAt(index);
            while (lines.Count > 0 && string.IsNullOrWhiteSpace(lines[0]))
            {
                lines.RemoveAt(0);
            }

            return (
                string.IsNullOrWhiteSpace(title) ? "Untitled Section" : title,
                headingLevel,
                string.Join(Environment.NewLine, lines).Trim());
        }

        return (
            string.IsNullOrWhiteSpace(fallbackTitle) ? "Untitled Section" : fallbackTitle.Trim(),
            Math.Clamp(fallbackHeadingLevel, 1, 6),
            normalizedContent.Trim());
    }

    private static bool TryParseMarkdownHeading(string line, out string title, out int headingLevel)
    {
        title = string.Empty;
        headingLevel = 0;
        var trimmed = line.TrimStart();

        while (headingLevel < trimmed.Length && headingLevel < 6 && trimmed[headingLevel] == '#')
        {
            headingLevel++;
        }

        if (headingLevel == 0 ||
            headingLevel >= trimmed.Length ||
            !char.IsWhiteSpace(trimmed[headingLevel]))
        {
            return false;
        }

        title = trimmed[headingLevel..].Trim().TrimEnd('#').Trim();
        return true;
    }

    private void SortCurrentSections()
    {
        _entries.Sort((left, right) =>
        {
            var order = left.SortOrder.CompareTo(right.SortOrder);
            return order != 0 ? order : left.Id.CompareTo(right.Id);
        });
    }

    private static int GetTreeIndent(ResumeSection entry)
    {
        var level = Math.Clamp(entry.HeadingLevel, 1, 6);
        return 14 + ((level - 1) * 18);
    }

}
