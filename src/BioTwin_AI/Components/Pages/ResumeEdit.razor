@page "/resume/edit"
@using BioTwin_AI.Data
@using BioTwin_AI.Models
@using BioTwin_AI.Services
@using Microsoft.EntityFrameworkCore
@using System.Text
@rendermode InteractiveServer
@inject BioTwinDbContext DbContext
@inject IRagService RagService
@inject CurrentUserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!_sessionResolved)
{
    <div class="container mt-4">
        <div class="alert alert-secondary">Loading session...</div>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <div class="container mt-4">
        <div class="alert alert-warning">Please sign in first.</div>
        <a class="btn btn-primary" href="/login">Go to Login</a>
    </div>
}
else
{
    <div class="resume-builder">
        <aside class="section-sidebar">
            <div class="section-sidebar-header">
                <div>
                    <h2>Resume Builder</h2>
                    <span>@_resumeEntries.Count resume@(_resumeEntries.Count == 1 ? "" : "s") - @_entries.Count section@(_entries.Count == 1 ? "" : "s")</span>
                </div>
                <button class="icon-action" title="New resume" @onclick="CreateResumeDraft">
                    +
                </button>
            </div>

            <div class="section-actions">
                <button class="btn btn-primary" @onclick="CreateResumeDraft">New Resume</button>
                <a class="btn btn-outline-primary" href="/resume/upload">Upload File</a>
            </div>

            @if (_resumeEntries.Count > 0)
            {
                <div class="resume-picker">
                    <div class="sidebar-kicker">Resume</div>
                    <select class="form-select resume-select"
                            aria-label="Select resume"
                            value="@GetSelectedResumeIndex()"
                            @onchange="OnResumeChanged">
                        @for (var index = 0; index < _resumeEntries.Count; index++)
                        {
                            var resume = _resumeEntries[index];
                            <option value="@index">@GetResumeTitle(resume) (@GetResumeSummary(resume))</option>
                        }
                    </select>
                </div>
            }

            @if (_resumeEntries.Count == 0)
            {
                <div class="empty-sections">
                    <strong>No resumes yet</strong>
                    <span>Upload a resume file or create a manual resume to get started.</span>
                </div>
            }
            else if (_selectedResumeEntry is null)
            {
                <div class="empty-sections">
                    <strong>Select a resume</strong>
                    <span>Choose which resume you want to edit.</span>
                </div>
            }
            else if (_entries.Count == 0)
            {
                <div class="empty-sections">
                    <strong>No sections in this resume</strong>
                    <span>Edit the full Markdown and save to rebuild navigation.</span>
                </div>
            }
            else
            {
                <div class="sidebar-kicker">Sections</div>
                <div class="section-tree" role="tree" aria-label="Resume section tree">
                    @foreach (var node in GetVisibleSectionNodes())
                    {
                        <div class="section-tree-row @(ReferenceEquals(_selectedEntry, node.Entry) ? "active" : "")"
                             style="--tree-depth: @node.Depth"
                             role="treeitem"
                             aria-level="@(node.Depth + 1)"
                             aria-selected="@ReferenceEquals(_selectedEntry, node.Entry)"
                             aria-expanded="@GetSectionAriaExpanded(node)">
                            <button type="button"
                                    class="section-tree-toggle"
                                    disabled="@(!node.HasChildren)"
                                    aria-label="@(IsSectionCollapsed(node.Entry) ? "Expand section" : "Collapse section")"
                                    @onclick="() => ToggleSectionNode(node.Entry)"
                                    @onclick:stopPropagation="true">
                                @if (node.HasChildren)
                                {
                                    <span>@(IsSectionCollapsed(node.Entry) ? ">" : "v")</span>
                                }
                            </button>
                            <button type="button"
                                    class="section-tree-title"
                                    @onclick="() => LocateSectionAsync(node.Entry)">
                                <span class="section-heading-text">@GetSectionDisplayTitle(node.Entry)</span>
                            </button>
                        </div>
                    }
                </div>
            }
        </aside>

        <main class="section-editor">
            <div class="editor-topbar">
                <a class="btn btn-secondary" href="/chat">Back to Chat</a>
                <div class="editor-actions">
                    @if (_selectedResumeEntry is not null)
                    {
                        <button class="btn btn-primary" @onclick="SaveWholeResumeAsync" disabled="@(_isSaving || string.IsNullOrWhiteSpace(_wholeResumeMarkdown))">
                            @(_isSaving ? "Saving..." : "Save Resume")
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="alert alert-success">@_message</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            @if (_selectedResumeEntry is null)
            {
                <div class="editor-empty-state">
                    <h3>Select a resume</h3>
                    <p>Choose a resume from the left panel before editing the full Markdown.</p>
                    <button class="btn btn-primary" @onclick="CreateResumeDraft">New Resume</button>
                </div>
            }
            else
            {
                <section class="section-workspace">
                    <div class="section-edit-pane">
                        <div class="section-meta-row">
                            <span>Editing @GetResumeTitle(_selectedResumeEntry)</span>
                            <span>@_entries.Count section@(_entries.Count == 1 ? "" : "s")</span>
                            <span>@GetWordCount(_wholeResumeMarkdown) words</span>
                            @if (!string.IsNullOrWhiteSpace(_selectedResumeEntry.SourceFileName) && _selectedResumeEntry.SourceFileName != ManualSourceName)
                            {
                                <span>Imported from @_selectedResumeEntry.SourceFileName</span>
                            }
                        </div>

                        <MarkdownEditor @ref="_fullResumeEditor"
                                        @bind-Value="_wholeResumeMarkdown"
                                        Label="Full Resume Markdown"
                                        Placeholder="Edit the whole resume in Markdown..."
                                        Rows="30" />
                    </div>
                </section>
            }
        </main>
    </div>
}

