{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rag": {
    "Provider": "sqlite-vec",
    "EmbeddingSize": 768
  },
  "MultiTenancy": {
    "DefaultTenantId": "default"
  },
  "All2MD": {
    "ApiUrl": "http://localhost:8000",
    "TimeoutSeconds": 600
  },
  "LLM": {
    "Provider": "Ollama",
    "BaseUrl": "http://localhost:11434",
    "Model": "gemma4:e2b",
    "EmbeddingModel": "nomic-embed-text",
    "ApiKey": "",
    "Temperature": 0.2,
    "Think": true,
    "MaxTokens": 800,
    "MaxContextChars": 2500,
    "MaxSnippetChars": 1200,
    "ChatNumPredict": 1024,
    "ChatNumCtx": 4096,
    "ChatTimeoutSeconds": 300,
    "EmbeddingTimeoutSeconds": 300
  },
  "ResumeMarkdownRefinement": {
    "Enabled": true,
    "Model": "gemma4:e2b",
    "Temperature": 0.1,
    "NumPredict": 3000,
    "NumCtx": 8192,
    "MaxTokens": 3000,
    "MaxInputChars": 24000,
    "TimeoutSeconds": 300
  }
}
