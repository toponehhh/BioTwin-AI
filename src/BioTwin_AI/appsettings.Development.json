{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Information"
    }
  },
  "MultiTenancy": {
    "DefaultTenantId": "default"
  },
  "All2MD": {
    "ApiUrl": "http://localhost:8000",
    "TimeoutSeconds": 600
  },
  "Rag": {
    "EmbeddingSize": 1024
  },
  "Embedding": {
    "Provider": "BgeM3Onnx",
    "ModelDirectory": "LLM",
    "ModelPath": "bge_m3_model.onnx",
    "TokenizerPath": "bge_m3_tokenizer.onnx",
    "MaxTokens": 8192
  },
  "LLM": {
    "Provider": "OpenRouter",
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Model": "openrouter/free",
    "ApiKey": "",
    "Temperature": 0.2,
    "Think": true,
    "MaxTokens": 800,
    "MaxContextChars": 2500,
    "MaxSnippetChars": 1200,
    "ChatNumPredict": 1024,
    "ChatNumCtx": 4096,
    "ChatTimeoutSeconds": 300
  },
  "ResumeMarkdownRefinement": {
    "Enabled": true,
    "Model": "openrouter/free",
    "Temperature": 0.1,
    "MaxTokens": 3000,
    "MaxInputChars": 24000,
    "TimeoutSeconds": 300
  }
}
