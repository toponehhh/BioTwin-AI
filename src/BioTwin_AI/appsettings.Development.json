{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MultiTenancy": {
    "DefaultTenantId": "default"
  },
  "All2MD": {
    "ApiUrl": "http://localhost:8000",
    "TimeoutSeconds": 600
  },
  "LLM": {
    "Provider": "OpenRouter",
    "BaseUrl": "https://openrouter.ai/api/v1",
    "Model": "openrouter/free",
    "EmbeddingModel": "nvidia/llama-nemotron-embed-vl-1b-v2:free",
    "ApiKey": "",
    "Temperature": 0.2,
    "Think": true,
    "MaxTokens": 800,
    "MaxContextChars": 2500,
    "MaxSnippetChars": 1200,
    "ChatNumPredict": 1024,
    "ChatNumCtx": 4096,
    "ChatTimeoutSeconds": 300,
    "EmbeddingTimeoutSeconds": 300
  },
  "ResumeMarkdownRefinement": {
    "Enabled": true,
    "Model": "openrouter/free",
    "Temperature": 0.1,
    "MaxTokens": 3000,
    "MaxInputChars": 24000,
    "TimeoutSeconds": 300
  }
}
