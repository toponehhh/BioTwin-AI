@page "/resume"
@inject IResumeApiClient IResumeApiClient
@inject SessionState SessionState

<PageTitle>Resume Library</PageTitle>

<ProtectedArea Title="Resume library requires sign in" Description="Stored resumes and private indexes are available only after signing in.">
    <section class="workspace-header">
        <p class="eyebrow">Resume Library</p>
        <h1>Indexed Resume Library</h1>
        <p>Review stored resume records, rebuild the private search index, and remove outdated imports.</p>
    </section>

    <div class="action-row">
        <button class="command-button" @onclick="RebuildAsync">Rebuild embeddings</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="status-line">@message</p>
    }

    <section class="grid-section">
        @if (resumes.Count == 0)
        {
            <article class="feature-card">
                <span>0 records</span>
                <h2>No indexed resumes</h2>
                <p>The library will show saved resume records after an upload workflow completes.</p>
            </article>
        }
        else
        {
            @foreach (var resume in resumes)
            {
                <article class="feature-card">
                    <span>@resume.SectionCount sections</span>
                    <h2>@resume.Title</h2>
                    <p>@(string.IsNullOrWhiteSpace(resume.SourceFileName) ? "Markdown source" : resume.SourceFileName)</p>
                    <p>Created @resume.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</p>
                    <button class="link-command" @onclick="() => DeleteAsync(resume.Id)">Delete</button>
                </article>
            }
        }
    </section>
</ProtectedArea>

@code {
    private IReadOnlyList<ResumeSummaryDto> resumes = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await SessionState.RefreshAsync();
        if (!SessionState.IsAuthenticated)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            resumes = await IResumeApiClient.GetResumesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task RebuildAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            return;
        }

        try
        {
            var result = await IResumeApiClient.RebuildEmbeddingsAsync();
            message = $"Rebuilt {result.SectionCount} sections across {result.ResumeCount} resumes.";
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteAsync(int resumeId)
    {
        if (!SessionState.IsAuthenticated)
        {
            return;
        }

        try
        {
            await IResumeApiClient.DeleteAsync(resumeId);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }
}
